# Copy to .env.local — never commit real secrets.

# --- Payload + database ---
DATABASE_URI=
PAYLOAD_SECRET=

# Preview: ?secret=...&slug=/path
PAYLOAD_DRAFT_SECRET=

# POST /api/revalidate — Authorization: Bearer <token>
REVALIDATION_SECRET=

# --- Contact form (Resend) ---
RESEND_API_KEY=
# Optional overrides (defaults: info@asymmetric.al inbox, Website <noreply@asymmetric.al> from)
# CONTACT_INBOX_EMAIL=
# CONTACT_FROM_EMAIL=

# --- Vercel Blob (enable when Media collection uses the plugin) ---
BLOB_READ_WRITE_TOKEN=

# --- Stripe (giving / donations; use Test mode keys locally) ---
# Never commit real keys. Create Prices in Dashboard (Products) and paste IDs here.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Monthly recurring price IDs (USD, recurring monthly) — e.g. $25 / $50 / $100
STRIPE_PRICE_RECURRING_25=
STRIPE_PRICE_RECURRING_50=
STRIPE_PRICE_RECURRING_100=

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://asymmetric.al

# Optional: bundle analysis
# ANALYZE=true
