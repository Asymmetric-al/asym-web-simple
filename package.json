    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "payload": "^3.79.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.9.4",
    "stripe": "^22.0.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
