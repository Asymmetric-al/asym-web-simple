{
  "name": "template-baseline",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx,.mjs",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx,.mjs --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,json,css,md}\"",
    "typecheck": "tsc --noEmit",
    "analyze:bundle": "node scripts/analyze-bundle.mjs",
    "qa:e2e": "playwright test",
    "qa:visual": "playwright test tests/visual",
    "qa:visual:update": "playwright test tests/visual --update-snapshots",
    "qa:a11y": "playwright test tests/a11y",
    "qa:smoke": "playwright test tests/e2e/smoke.spec.ts",
    "payload": "payload",
    "generate:types": "payload generate:types",
    "generate:importmap": "payload generate:importMap"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
